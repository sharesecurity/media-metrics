# Media Metrics — Environment Variables
# Copy this to .env and adjust as needed

# Database
DATABASE_URL=postgresql+asyncpg://media:media_metrics_2024@postgres:5432/media_metrics

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# MinIO
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=media_metrics
MINIO_SECRET_KEY=media_metrics_2024
MINIO_BUCKET=articles

# Ollama (native on host — accessible via host.docker.internal from Docker)
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=deepseek-r1:8b

# Anthropic (optional — for Claude fallback)
ANTHROPIC_API_KEY=
